# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# convex
/.convex/

# orchestrator local state
/.orchestrator/*.local.*
.env*.local

# clerk configuration (can include secrets)
/.clerk/

# generated podcasts (large MP3s, served from CDN)
/public/podcasts/

# raw research inputs (regenerable)
/transcripts/
/raw-data/

# audit residues (screenshots, scratch reports)
/.debugaudit/
/.uiuxaudit/
/.flowaudit/
/.audit/

# local Claude state
/.claude/

# scratch / one-off scripts at repo root
/build_report.py
/run_analysis.py
/niche-analysis-report.html
/scripts/gen-podcasts-fast.sh
